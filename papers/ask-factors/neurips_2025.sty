% neurips_2025.sty — Minimal NeurIPS 2025 style for compilation
% This is a simplified version for draft compilation.
% Replace with the official neurips_2025.sty for camera-ready submission.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 Style (minimal)]

% Process options
\newif\if@neurips@final\@neurips@finalfalse
\newif\if@neurips@preprint\@neurips@preprintfalse
\DeclareOption{final}{\@neurips@finaltrue}
\DeclareOption{preprint}{\@neurips@preprinttrue}
\DeclareOption{main}{}
\DeclareOption{position}{}
\DeclareOption{dandb}{}
\DeclareOption{creativeai}{}
\DeclareOption{sglblindworkshop}{}
\DeclareOption{dblblindworkshop}{}
\DeclareOption{nonatbib}{}
\ProcessOptions\relax

% Page layout
\usepackage[letterpaper,margin=1in,top=1in,bottom=1in]{geometry}

% natbib for citations
\usepackage[numbers,sort&compress]{natbib}

% Title formatting
\def\@maketitle{%
  \newpage
  \null
  \vskip 2em%
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 1.5em%
    {\large
      \lineskip .5em%
      \begin{tabular}[t]{c}%
        \if@neurips@final
          \@author
        \else
          \if@neurips@preprint
            \@author
          \else
            Anonymous Author(s)
          \fi
        \fi
      \end{tabular}\par}%
    \vskip 1em%
    {\large \@date}%
  \end{center}%
  \par
  \vskip 1.5em}

% Abstract
\renewenvironment{abstract}%
  {\centerline{\large\bfseries Abstract}%
   \vspace{0.5ex}%
   \begin{quote}}%
  {\par\end{quote}\vskip 1ex}

% Acknowledgments — simplified: just use a section
\newenvironment{ack}{\section*{Acknowledgments}}{}

% Checklist macros
\newcommand{\answerYes}[1][]{\textbf{Yes.} #1}
\newcommand{\answerNo}[1][]{\textbf{No.} #1}
\newcommand{\answerNA}[1][]{\textbf{N/A.} #1}
\newcommand{\answerTODO}[1][]{\textbf{TODO.} #1}
\newcommand{\justificationTODO}[1][]{\textbf{TODO.} #1}

% Workshop title (no-op in main track)
\newcommand{\workshoptitle}[1]{}

\endinput
