#!/usr/bin/env python3
from __future__ import annotations

import sys
import tomllib
from pathlib import Path


def _load_project_name(pyproject_path: Path) -> str | None:
    try:
        data = tomllib.loads(pyproject_path.read_text(encoding="utf-8"))
    except (FileNotFoundError, OSError, tomllib.TOMLDecodeError):
        return None
    project = data.get("project")
    if not isinstance(project, dict):
        return None
    name = project.get("name")
    return name if isinstance(name, str) else None


def _inject_source_checkout() -> None:
    current = Path.cwd().resolve()
    for candidate in (current, *current.parents):
        pyproject_path = candidate / "pyproject.toml"
        cli_path = candidate / "src" / "pepper" / "cli.py"
        if _load_project_name(pyproject_path) != "pepper":
            continue
        if not cli_path.exists():
            continue
        src_dir = str(candidate / "src")
        if src_dir not in sys.path:
            sys.path.insert(0, src_dir)
        return


def main() -> int:
    _inject_source_checkout()
    from pepper.cli import main as cli_main

    return cli_main()


if __name__ == "__main__":
    raise SystemExit(main())
