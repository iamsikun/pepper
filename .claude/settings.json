{
  "env": {
    "PAPER_SYSTEM_VERSION": "3.0",
    "PEPPER_CANONICAL_INTERFACE": "pepper-cli"
  },
  "permissions": {
    "allow": [
      "Bash(pdflatex:*)",
      "Bash(bibtex:*)",
      "Bash(xelatex:*)",
      "Bash(lualatex:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(zip:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(ls:*)",
      "Bash(pepper:*)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": []
  }
}
